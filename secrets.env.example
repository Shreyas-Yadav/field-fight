# Copy this file to secrets.env and fill in real values.
# secrets.env is gitignored.
#
# Used by `bash scripts/recreate-dev.sh secrets` to create the
# Kubernetes Secret named field-fight-dev-secrets.

# RDS master password. Must match TF_VAR_db_password used during terraform apply.
DB_PASSWORD=rootroot

# Per-deploy random secret for JWT signing.
# Regenerate with: openssl rand -hex 32
JWT_SECRET=replace-with-output-of-openssl-rand-hex-32

# Google OAuth credentials for the dev environment.
# Create in Google Cloud Console > APIs & Services > Credentials.
# Authorized redirect URI: https://field-fight-dev.shri.software/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth credentials for the dev environment.
# Create in GitHub > Settings > Developer settings > OAuth Apps.
# Authorization callback URL: https://field-fight-dev.shri.software/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Observability (Phase 5c) ---

# GitHub OAuth credentials for Grafana (separate OAuth app).
# Create in GitHub > Settings > Developer settings > OAuth Apps > New OAuth App.
# Authorization callback URL: https://grafana-dev.shri.software/login/github
GF_AUTH_GITHUB_CLIENT_ID=
GF_AUTH_GITHUB_CLIENT_SECRET=

# Comma-separated list of GitHub orgs allowed to log in to Grafana.
# Use your personal username if you don't have an org: e.g. "Shreyas-Yadav"
# (Grafana will look up org membership; for a personal account, this acts as
# allowed-users via the "user:email" scope.)
GF_AUTH_GITHUB_ALLOWED_ORGS=

# Slack incoming webhook URL for Alertmanager.
# Create in Slack: Apps > Incoming Webhooks > Add to workspace > pick channel.
SLACK_WEBHOOK_URL=
